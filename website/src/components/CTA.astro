<section class="section container cta-section">
    <div class="card-padded">
        <span class="swiss-badge">100% Offline & Private</span>
        <h2 class="display-lg">Your data is yours.</h2>
        <p class="body-md cta-desc">No accounts. No sign-ups. No ads. No tracking telemetry. Spaced works completely offline. You can export your entire database to a single JSON file and restore it anywhere, anytime.</p>
        
        <div class="cta-actions">
            <a href="https://github.com/thekbbohara/spaced/releases/latest" class="btn btn-primary">Download APK</a>
            <a href="https://github.com/thekbbohara/spaced" class="btn btn-secondary">View GitHub</a>
        </div>
        <p class="body-sm cta-note">Play Store release coming soon.</p>
    </div>
</section>

<style>
    .cta-section { padding-bottom: 0; }

    .cta-desc {
        max-width: 600px;
        margin: 24px auto 32px;
    }

    .cta-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .cta-note { margin-top: 24px; }
</style>
