---
---
<header class="header-wrapper">
    <nav class="floating-nav">
        <a href="/" class="brand">
            <img src="/images/icon.png" alt="" width="24" height="24" onerror="this.style.display='none'">
            <span class="brand-text">Spaced</span>
        </a>
        
        <div class="desktop-links">
            <a href="#research" class="nav-link">Science</a>
            <a href="#compare" class="nav-link">Compare</a>
            <a href="#features" class="nav-link">Features</a>
        </div>

        <div class="nav-actions">
            <a href="https://github.com/thekbbohara/spaced/releases/latest" class="btn-primary-small desktop-only">Download Beta</a>
            <button class="hamburger-btn" id="menuToggle" aria-label="Open menu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
            </button>
        </div>
    </nav>
</header>

<!-- Mobile Menu Overlay (Outside of the header to avoid backdrop-filter trapping) -->
<div class="mobile-overlay" id="mobileMenu">
    <div class="mobile-overlay-header">
        <a href="/" class="brand">
            <img src="/images/icon.png" alt="" width="24" height="24" onerror="this.style.display='none'">
            <span class="brand-text">Spaced</span>
        </a>
        <button class="close-btn" id="menuClose" aria-label="Close menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>
    <div class="mobile-links">
        <a href="#research" class="mobile-link">The Science</a>
        <a href="#compare" class="mobile-link">Compare</a>
        <a href="#features" class="mobile-link">Features</a>
        <div class="mobile-action-wrap">
            <a href="https://github.com/thekbbohara/spaced/releases/latest" class="btn-primary-large">Download Beta</a>
        </div>
    </div>
</div>

<script>
    const toggleBtn = document.getElementById('menuToggle');
    const closeBtn = document.getElementById('menuClose');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileLinks = mobileMenu?.querySelectorAll('a');

    function openMenu() {
        mobileMenu?.classList.add('is-active');
        document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
        mobileMenu?.classList.remove('is-active');
        document.body.style.overflow = '';
    }

    toggleBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    
    mobileLinks?.forEach(link => {
        link.addEventListener('click', closeMenu);
    });
</script>

<style>
    /* Floating Header Wrapper */
    .header-wrapper {
        position: fixed;
        top: 24px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: center;
        z-index: 100;
        padding: 0 24px;
        pointer-events: none; /* Let clicks pass through the wrapper */
    }

    /* The actual glassmorphism pill */
    .floating-nav {
        pointer-events: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04), 0 2px 8px rgba(0, 0, 0, 0.02);
        border-radius: 999px;
        padding: 8px 8px 8px 24px;
        width: 100%;
        max-width: 900px;
        height: 56px;
        transition: all 0.3s ease;
    }

    /* Brand */
    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .brand img {
        border-radius: 6px;
    }

    .brand-text {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 16px;
        color: var(--primary);
        letter-spacing: -0.3px;
    }

    /* Desktop Links */
    .desktop-links {
        display: flex;
        align-items: center;
        gap: 28px;
    }

    .nav-link {
        font-size: 14px;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .nav-link:hover {
        color: var(--primary);
    }

    /* Actions */
    .nav-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-primary-small {
        background: var(--primary);
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        padding: 10px 20px;
        border-radius: 999px;
        text-decoration: none;
        transition: transform 0.2s ease, background 0.2s ease;
    }

    .btn-primary-small:hover {
        background: var(--primary-active);
        transform: scale(1.02);
    }

    .hamburger-btn {
        display: none;
        background: var(--surface-card);
        border: 1px solid var(--hairline);
        color: var(--primary);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .hamburger-btn:hover {
        background: var(--hairline);
    }

    /* Mobile Overlay */
    .mobile-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-overlay.is-active {
        opacity: 1;
        pointer-events: auto;
    }

    .mobile-overlay-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 32px;
    }

    .close-btn {
        background: var(--surface-card);
        border: 1px solid var(--hairline);
        color: var(--primary);
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .mobile-links {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 32px;
        gap: 32px;
    }

    .mobile-link {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        letter-spacing: -1px;
        transform: translateY(20px);
        opacity: 0;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    }

    .mobile-overlay.is-active .mobile-link {
        transform: translateY(0);
        opacity: 1;
    }

    /* Stagger the entrance animation for links */
    .mobile-overlay.is-active .mobile-link:nth-child(1) { transition-delay: 0.1s; }
    .mobile-overlay.is-active .mobile-link:nth-child(2) { transition-delay: 0.15s; }
    .mobile-overlay.is-active .mobile-link:nth-child(3) { transition-delay: 0.2s; }
    .mobile-overlay.is-active .mobile-link:nth-child(4) { transition-delay: 0.25s; }

    .mobile-action-wrap {
        margin-top: auto;
        padding-bottom: 48px;
        transform: translateY(20px);
        opacity: 0;
        transition: transform 0.4s ease 0.3s, opacity 0.4s ease 0.3s;
    }

    .mobile-overlay.is-active .mobile-action-wrap {
        transform: translateY(0);
        opacity: 1;
    }

    .btn-primary-large {
        display: block;
        background: var(--primary);
        color: #fff;
        text-align: center;
        font-size: 16px;
        font-weight: 600;
        padding: 16px;
        border-radius: 16px;
        text-decoration: none;
    }

    @media (max-width: 900px) {
        .header-wrapper {
            top: 16px;
            padding: 0 16px;
        }

        .floating-nav {
            padding: 6px 6px 6px 20px;
        }

        .desktop-links, .desktop-only {
            display: none;
        }

        .hamburger-btn {
            display: flex;
        }
    }
</style>
